{
  "name": "have-you-seen-my-shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --configLoader runner",
    "dev:worker": "wrangler dev",
    "dev": "concurrently -n frontend,worker -c cyan,green \"npm run dev:frontend\" \"npm run dev:worker\"",
    "build": "vite build --configLoader runner",
    "typecheck": "tsc --noEmit",
    "deploy": "npm run build && wrangler deploy",
    "d1:migrate": "wrangler d1 migrations apply have-you-seen-my-shell",
    "d1:seed": "wrangler d1 execute have-you-seen-my-shell --file=scripts/seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260108.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.1",
    "wrangler": "^4.11.1"
  }
}
